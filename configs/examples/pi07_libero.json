{
    "dataset_mixture": {
        "datasets": [
            {
                "repo_id": "TensorAuto/libero"
            }
        ],
        "weights": [1.0],
        "action_freq": 20.0,
        "image_resample_strategy": "nearest",
        "vector_resample_strategy": "nearest",
        "val_split_ratio": 0.05,
        "history_state_drop_prob": 1.0,
        "subgoal_drop_prob": 1.0,
        "subgoal_end_of_segment_prob": 0.25,
        "response_drop_prob": 1.0,
        "metadata_drop_all_prob": 1.0,
        "metadata_drop_each_prob": 1.0,
        "val_enable_optional_key_dropout": false
    },
    "policy": {
        "type": "pi07_paligemma_low_level",
        "pretrained_path": "TensorAuto/pi05_base",
        "n_obs_steps": 1,
        "normalization_mapping": {
            "VISUAL": "IDENTITY",
            "STATE": "MIN_MAX",
            "ACTION": "MEAN_STD"
        },
        "chunk_size": 10,
        "n_action_steps": 10,
        "max_state_dim": 32,
        "max_action_dim": 32,
        "resize_imgs_with_padding": [224, 224],
        "empty_cameras": 0,
        "proj_width": 1024,
        "num_steps": 10,
        "max_delay": 0,
        "attention_implementation": "eager",
        "freeze_vision_encoder": true,
        "train_expert_only": true,
        "prompt_max_length": 100,
        "response_max_length": 52,
        "metadata_max_length": 52,
        "discrete_action_max_length": 60,
        "spacetime_layer_stride": 4,
        "optimizer_lr": 2.5e-5,
        "optimizer_betas": [0.9, 0.95],
        "optimizer_eps": 1e-8,
        "optimizer_weight_decay": 1e-10,
        "scheduler_warmup_steps": 1000,
        "scheduler_decay_steps": 30000,
        "scheduler_decay_lr": 2.5e-6
    },
    "resume": false,
    "seed": 1000,
    "resolution": [224, 224],
    "num_cams": 2,
    "max_state_dim": 32,
    "max_action_dim": 32,
    "action_chunk": 10,
    "loss_weighting": {"MSE": 1, "CE": 1},
    "num_workers": 8,
    "batch_size": 2,
    "gradient_accumulation_steps": 1,
    "dataloader_batch_size": 2,
    "prefetch_factor": 8,
    "steps": 100,
    "log_freq": 5,
    "save_checkpoint": true,
    "save_freq": 1000,
    "val_freq": 1000,
    "use_policy_training_preset": false,
    "trace_nans": false,
    "optimizer": {
        "type": "adamw",
        "lr": 2.5e-5,
        "weight_decay": 1e-10,
        "grad_clip_norm": 10.0,
        "betas": [0.9, 0.95],
        "eps": 1e-8
    },
    "scheduler": {
        "type": "cosine_decay_with_warmup",
        "num_warmup_steps": 1000,
        "num_decay_steps": 30000,
        "peak_lr": 2.5e-5,
        "decay_lr": 2.5e-6
    },
    "wandb": {
        "enable": true,
        "entity": "wyautox-autox",
        "project": "pi07",
        "run_id": null,
        "name": null,
        "notes": "PI07 low-level training (Libero)",
        "tags": [],
        "group": null,
        "job_type": null,
        "mode": null,
        "on_resume": "fork",
        "disable_artifact": false
    },
    "env": {
        "type": "libero",
        "task": "libero_10",
        "fps": 20,
        "max_parallel_tasks": 1,
        "task_ids": [0, 1, 2, 3, 4, 5, 6, 8],
        "episode_length": 700,
        "obs_type": "pixels_agent_pos",
        "render_mode": "rgb_array",
        "camera_name": "agentview_image,robot0_eye_in_hand_image",
        "init_states": true,
        "camera_name_mapping": null
